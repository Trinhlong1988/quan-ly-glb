{
  "name": "quan-ly-glb",
  "version": "0.2.60",
  "private": true,
  "description": "Quản Lý GLB — Internal Management System (IMS). G1 Phase A foundation + auth slice.",
  "workspaces": [
    "packages/shared",
    "packages/business-rules",
    "packages/database",
    "apps/desktop"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @glb/desktop",
    "build": "npm run build --workspace @glb/desktop",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspace @glb/desktop",
    "audit:protected": "node tools/audit/protected_artifacts_guard.mjs",
    "audit:deferred": "node tools/audit/deferred_guard.mjs",
    "verify": "npm run typecheck && npm run audit:protected && npm run audit:deferred && npm run test",
    "selftest": "node tools/selftest/run-selftest-pg.mjs",
    "selftest:bill": "node tools/selftest/run-selftest-pg.mjs 44",
    "selftest:core": "node tools/selftest/run-selftest-pg.mjs 2 15 44",
    "db:generate": "npm run generate --workspace @glb/database",
    "db:migrate": "npm run migrate --workspace @glb/database",
    "db:seed": "npm run seed --workspace @glb/database",
    "db:reset": "npm run reset --workspace @glb/database",
    "db:setup": "npm run generate --workspace @glb/database && npm run migrate --workspace @glb/database && npm run seed --workspace @glb/database"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20"
  }
}
