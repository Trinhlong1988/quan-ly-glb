{
  "name": "@glb/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev --name init",
    "reset": "prisma migrate reset --force",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@glb/business-rules": "*",
    "@glb/shared": "*",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2"
  }
}
