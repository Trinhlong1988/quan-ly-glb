// Quản Lý GLB — IMS G1 schema (IMS_SPEC §18). 9 bảng.
// SQLite local (G1) → PostgreSQL VPS (G10): giữ nguyên model, chỉ đổi provider + url.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int       @id @default(autoincrement())
  employeeCode        String?   @unique @map("employee_code") // mã NV (§D) — NV01, NV02...
  fullName            String    @map("full_name")
  birthDate           DateTime? @map("birth_date")
  gender              String?
  phone               String?
  email               String?   @unique
  address             String?
  joinDate            DateTime? @map("join_date")
  username            String    @unique
  passwordHash        String    @map("password_hash")
  status              String    @default("ACTIVE") // ACTIVE|PENDING|LOCKED|DISABLED|DELETED
  forceChangePassword Boolean   @default(false) @map("force_change_password")
  failedAttempts      Int       @default(0) @map("failed_attempts") // đếm mọi lần xác thực SAI (đăng nhập/đổi mật khẩu/pass cấp 2). ≥5 → tự khóa
  lockedAt            DateTime? @map("locked_at") @db.Timestamptz(3) // thời điểm bị tự khóa do sai quá số lần
  level2Hash          String?   @map("level2_hash") // băm bcrypt (cost cao) mật khẩu CẤP 2 — chỉ Admin/Manager đặt; dùng cho xóa vĩnh viễn
  level2SetAt         DateTime? @map("level2_set_at") @db.Timestamptz(3)
  createdBy           Int?      @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(3)

  roles     UserRole[]
  auditLogs AuditLog[]     @relation("actor")
  sessions  LoginSession[]

  @@map("users")
}

// Thư nội bộ + thông báo hệ thống (hòm thư dùng chung).
// kind=SYSTEM (thông báo bảo mật, senderId null) | USER (thư người dùng gửi nhau — Nhóm C).
model Message {
  id          Int       @id @default(autoincrement())
  kind        String    @default("USER") // USER | SYSTEM
  category    String? // SECURITY_LOCK | SECURITY_RESET | ... (phân loại thông báo hệ thống)
  subject     String
  body        String
  senderId    Int?      @map("sender_id") // null = hệ thống
  recipientId Int       @map("recipient_id")
  readAt      DateTime? @map("read_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([recipientId, deletedAt])
  @@map("messages")
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  description String?
  status      String    @default("ACTIVE") // ACTIVE|LOCKED
  isSystem    Boolean   @default(false) @map("is_system")
  createdBy   Int?      @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(3)

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  group       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       Int      @map("role_id")
  permissionId Int      @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?     @map("actor_user_id")
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  beforeJson  String?  @map("before_json")
  afterJson   String?  @map("after_json")
  ipAddress   String?  @map("ip_address")
  deviceInfo  String?  @map("device_info")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  actor User? @relation("actor", fields: [actorUserId], references: [id])

  @@map("audit_logs")
}

model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("app_settings")
}

model BackupLog {
  id        Int      @id @default(autoincrement())
  filePath  String   @map("file_path")
  fileSize  Int?     @map("file_size")
  checksum  String?
  createdBy Int?     @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  note      String?

  @@map("backup_logs")
}

// R46 (Mr.Long 12/7) — 1 tài khoản chỉ đăng nhập 1 THIẾT BỊ cùng lúc. lastSeenAt = nhịp tim (heartbeat) để
// phát hiện phiên còn sống (online) + dọn phiên chết; deviceInfo hiển thị "đang đăng nhập ở thiết bị khác".
model LoginSession {
  id         String   @id
  userId     Int      @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(3)
  lastSeenAt DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  deviceInfo String?  @map("device_info")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// G-POS.1 — POS/TID asset library (event-sourced) + code counter (§A/§D).
// Asset tables use scalar id links (no hard FK) to keep the immutable event log
// resilient to soft-deletes/renames; joins are done in the service layer.
// ─────────────────────────────────────────────────────────────────────────────

// Đại lý (§A2).
model Agent {
  id        Int       @id @default(autoincrement())
  code      String?   @unique
  name      String
  region    String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("agents")
}

// Khách hàng / điểm bán (§A2/§D). Mã KH## + nickname bắt buộc ("dễ gọi").
model Customer {
  id        Int       @id @default(autoincrement())
  code      String    @unique // KH01, KH02...
  fullName  String    @map("full_name") // tên thật
  nickname  String // biệt danh dễ gọi — BẮT BUỘC (§D)
  status    String    @default("ACTIVE") // ACTIVE (đang hoạt động) | LOCKED (đã khóa, chặn GD mới) | CANCELLED (đã hủy, ẩn khỏi list mặc định)
  phone     String?
  email     String?
  address   String?
  agentId   Int?      @map("agent_id")
  note      String?
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("customers")
}

// Máy POS vật lý — danh tính = serial number bất biến (§A2).
// PHASE K1 (Q-P1/Q-P4): PosDevice = NGUỒN SỰ THẬT DUY NHẤT của 1 máy. Di trú các cột nhập từ
// PosIntake sang đây (nullable — không phá dữ liệu cũ). GIỮ cột model/bank text (Q-P4, không xóa ở
// pha K) + thêm FK posModelId/bankId/supplierId/intakeStatusId. Bổ sung audit + soft-delete như các
// bảng khác. Link scalar (no hard FK) — nhất quán triết lý event-log ở đầu file.
model PosDevice {
  id                Int      @id @default(autoincrement())
  serial            String   @unique
  model             String?
  bank              String?
  status            String   @default("IN_STOCK") // IN_STOCK|DEPLOYED|IN_REPAIR|DAMAGED|RETIRED
  currentAgentId    Int?     @map("current_agent_id")
  currentCustomerId Int?     @map("current_customer_id")
  currentTid        String?  @map("current_tid")
  warehouseLoc      String?  @map("warehouse_loc")
  note              String?
  // ── PHASE K1 §2.1 — cột nhập di trú từ PosIntake (nullable) ──
  posModelId        Int?      @map("pos_model_id") // FK PosModel (§C7) — thay model text (Q-P4)
  supplierId        Int?      @map("supplier_id") // NCC nhập gần nhất (§C6)
  intakeStatusId    Int?      @map("intake_status_id") // trạng thái nhập (§C8a)
  importPrice       Int?      @map("import_price") // giá nhập gần nhất (VND)
  importedAt        DateTime? @map("imported_at") @db.Timestamptz(3) // ngày nhập gần nhất
  bankId            Int?      @map("bank_id") // FK Bank (§C1) — thay bank text (Q-P4)
  // ── audit + soft-delete (BỔ SUNG — trước đây thiếu) ──
  createdBy         Int?      @map("created_by")
  updatedBy         Int?      @map("updated_by")
  deletedBy         Int?      @map("deleted_by")
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([posModelId])
  @@index([supplierId])
  @@map("pos_devices")
}

// Terminal ID (§A2).
model Tid {
  id               Int       @id @default(autoincrement())
  tid              String    @unique
  mid              String?
  bank             String? // legacy text (G-POS.1) — giữ tương thích
  status           String    @default("UNASSIGNED") // vòng đời vận hành: UNASSIGNED|ACTIVE|DEAD|CLOSED|RECALLED
  posSerial        String?   @map("pos_serial")
  customerId       Int?      @map("customer_id")
  agentId          Int?      @map("agent_id")
  openedAt         DateTime? @map("opened_at") @db.Timestamptz(3)
  deliveredAt      DateTime? @map("delivered_at") @db.Timestamptz(3)
  closedAt         DateTime? @map("closed_at") @db.Timestamptz(3)
  // ── G-CFG.6 §9 Cấu hình TID (Cách 1: gộp thông tin thương mại vào chính bảng tids) ──
  bankId           Int?      @map("bank_id") // Ngân hàng (chọn từ danh sách, thay text `bank`)
  partnerId        Int?      @map("partner_id") // Đối tác → tra biểu phí
  hkdName          String?   @map("hkd_name") // Tên Hộ Kinh Doanh của máy POS
  receiveAccountId Int?      @map("receive_account_id") // TK nhận tiền (§8)
  issuedAt         DateTime? @map("issued_at") @db.Timestamptz(3) // Ngày cấp TID (§9)
  configStatusId   Int?      @map("config_status_id") // Trạng thái TID cấu hình (§9a)
  dossierSourceId  Int?      @map("dossier_source_id") // Nguồn hồ sơ (§10a)
  note             String?
  // ── PHASE K2 (§5/§8) — hợp nhất TID + máy của khách (Q-T6) + link HKD (Q-T3) ──
  customerDeviceSerial String? @map("customer_device_serial") // Q-T6: serial máy CỦA KHÁCH (không tạo PosDevice)
  dossierId        Int?      @map("dossier_id") // Q-T3: link Hồ sơ HKD (Dossier); giữ hkdName text để hiển thị/backfill
  // ── LANE A (#11) — Ngành nghề cho TID ──
  industryId       Int?      @map("industry_id") // #11: Ngành nghề (Industry). Nullable ở DB (TID cũ = null);
  //                                                "bắt buộc" enforce ở tầng tạo (createTidUnified), không phá dữ liệu cũ.
  createdBy        Int?      @map("created_by")
  updatedBy        Int?      @map("updated_by")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(3) // soft-delete cho cấu hình TID (§9b)
  deletedBy        Int?      @map("deleted_by")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([partnerId])
  @@index([bankId])
  @@index([dossierId])
  @@index([industryId])
  @@map("tids")
}

// Giao dịch (Nhóm B §Doanh thu) — mỗi lần quẹt/rút qua 1 TID cho 1 khách.
// Doanh thu = BÓC 2 khoản chênh cộng gộp (LEAD 9/7):
//   • CL_NCC (chênh đối tác) = phí mua − phí cài máy  → đối soát/thu từ đối tác
//   • CL_KH  (chênh bán)     = phí bán − phí cài máy  → thu từ khách
//   Doanh thu = số tiền × (CL_NCC% + CL_KH%). Cả 2 khoản = CÔNG NỢ thu về.
// Phí lưu snapshot (×1000) để không đổi khi biểu phí đổi. Lọc TID/MID/HKD/khách dẫn xuất từ tidId.
model Transaction {
  id                 Int       @id @default(autoincrement())
  code               String?   @unique // GD00001…
  tidId              Int       @map("tid_id")
  customerId         Int?      @map("customer_id")
  cardTypeId         Int?      @map("card_type_id")
  amount             Int // số tiền giao dịch (VND)
  partnerMarginMilli Int       @default(0) @map("partner_margin_milli") // CL_NCC = phiMua−phiCaiMay (×1000)
  sellMarginMilli    Int       @default(0) @map("sell_margin_milli") // CL_KH = phiBan−phiCaiMay (×1000)
  revenuePartner     Int       @default(0) @map("revenue_partner") // đối soát đối tác (VND)
  revenueSell        Int       @default(0) @map("revenue_sell") // thu khách (VND)
  revenueAmount      Int       @default(0) @map("revenue_amount") // tổng doanh thu = partner + sell (VND)
  settled            Boolean   @default(false) // đã thu/đối soát chưa (cho công nợ)
  settledAt          DateTime? @map("settled_at") @db.Timestamptz(3)
  txnDate            DateTime  @map("txn_date")
  note               String?
  // P1.2 — chứng từ bất biến: bill không sửa; sai thì HỦY qua duyệt. status POSTED|CANCEL_PENDING|CANCELLED.
  status             String    @default("POSTED")
  cancelReason       String?   @map("cancel_reason")
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz(3)
  cancelRequestId    Int?      @map("cancel_request_id")
  // H2b — Phân loại chất lượng công nợ: GOOD (Dễ thu hồi) | HARD (Khó thu hồi) | BAD (Không thu hồi).
  // null = CHƯA phân loại. Đổi qua classifyDebt (perm DEBT_CLASSIFY) + ghi DebtQualityLog + audit.
  debtQuality        String?   @map("debt_quality")
  // H2b — Ghi giảm nợ xấu (write-off, Q-F): đánh dấu GD BAD đã ghi giảm → RỚT khỏi công nợ, CẤM ghi
  // giảm 2 lần (idempotent). Sinh 1 CashEntry CHI "Chi phí nợ xấu" affectsPnl=true = nợ net còn lại.
  writtenOffAt       DateTime? @map("written_off_at") @db.Timestamptz(3)
  writtenOffBy       Int?      @map("written_off_by")
  createdBy          Int?      @map("created_by")
  updatedBy          Int?      @map("updated_by")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy          Int?      @map("deleted_by")

  @@index([tidId])
  @@index([customerId])
  @@index([txnDate])
  @@index([status])
  @@index([debtQuality])
  @@map("transactions")
}

// P1.2 — Approval Engine (generic). 1 dòng = 1 yêu cầu duyệt trên 1 thực thể (P1.2 = Transaction, action CANCEL).
// Sau tái dùng cho phiếu thu/chi/nhập/xuất. status PENDING|APPROVED|REJECTED. KHÔNG @@unique.
model ApprovalRequest {
  id           Int       @id @default(autoincrement())
  entityType   String    @map("entity_type") // 'Transaction'
  entityId     Int       @map("entity_id")
  action       String // 'CANCEL'
  reason       String
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED
  requestedBy  Int       @map("requested_by")
  requestedAt  DateTime  @default(now()) @map("requested_at") @db.Timestamptz(3)
  decidedBy    Int?      @map("decided_by")
  decidedAt    DateTime? @map("decided_at") @db.Timestamptz(3)
  decisionNote String?   @map("decision_note")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([entityType, entityId])
  @@index([status])
  @@map("approval_requests")
}

// Trạng thái TID cấu hình (§9a) — ví dụ: mới cấp, thu hồi, đổi cho đối tác. Khác status vận hành.
model TidConfigStatus {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("tid_config_statuses")
}

// NHẬT KÝ BẤT BIẾN (§A1) — mọi sự kiện vòng đời POS/TID. Không sửa/xóa.
model AssetEvent {
  id           Int      @id @default(autoincrement())
  deviceSerial String?  @map("device_serial")
  tid          String?
  eventType    String   @map("event_type")
  fromState    String?  @map("from_state")
  toState      String?  @map("to_state")
  fromAgentId  Int?     @map("from_agent_id")
  toAgentId    Int?     @map("to_agent_id")
  customerId   Int?     @map("customer_id")
  actorUserId  Int?     @map("actor_user_id")
  occurredAt   DateTime @map("occurred_at") @db.Timestamptz(3) // thời gian thao tác thực (≠ createdAt)
  note         String?
  beforeJson   String?  @map("before_json")
  afterJson    String?  @map("after_json")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([deviceSerial])
  @@index([tid])
  @@map("asset_events")
}

// Gắn POS↔TID theo thời gian (§A2) — giữ lịch sử bind/unbind.
model PosTidBinding {
  id           Int       @id @default(autoincrement())
  posSerial    String    @map("pos_serial")
  tid          String
  boundAt      DateTime  @map("bound_at") @db.Timestamptz(3)
  unboundAt    DateTime? @map("unbound_at") @db.Timestamptz(3)
  unbindReason String?   @map("unbind_reason")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([posSerial])
  @@index([tid])
  @@map("pos_tid_bindings")
}

// Bộ đếm sinh mã atomic (§D) — NV/KH/POS... zero-pad ≥2.
model CodeCounter {
  prefix    String   @id
  lastValue Int      @default(0) @map("last_value")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("code_counters")
}

// ─────────────────────────────────────────────────────────────────────────────
// G-CFG.1 — Cấu hình ngân hàng (§C1–C4). Ngân hàng · Loại thẻ (POS) · Đối tác ·
// liên kết Đối tác↔Ngân hàng (many-to-many). Mọi bảng có yếu tố truy vết
// (createdBy/updatedBy + timestamps) + soft-delete (deletedAt). Không hard FK để
// event log/audit bền với soft-delete/rename; join ở service layer.
// ─────────────────────────────────────────────────────────────────────────────

// Ngân hàng (§C1/C2). Mã ngân hàng unique.
model Bank {
  id        Int       @id @default(autoincrement())
  seq       Int?      @unique // số thứ tự tuần tự → hiển thị NH01, NH02... (gán khi tạo, cố định)
  name      String
  code      String    @unique // VCB, TCB... (unique, không phân biệt hoa/thường ở service)
  status    String    @default("ACTIVE") // ACTIVE | INACTIVE (ngân hàng ngừng dùng — vẫn giữ, không gợi ý khi tạo TID)
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("banks")
}

// Loại thẻ dùng trên máy POS (§C3) — thuộc 1 ngân hàng. Mã loại thẻ unique trong 1 ngân hàng (enforce ở service).
model CardType {
  id        Int       @id @default(autoincrement())
  bankId    Int       @map("bank_id")
  name      String
  code      String
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@index([bankId])
  @@map("card_types")
}

// Đối tác (§C4). Mã đối tác unique.
model Partner {
  id            Int       @id @default(autoincrement())
  name          String
  code          String    @unique
  status        String    @default("UNSIGNED") // trạng thái hợp đồng hợp tác: SIGNED | UNSIGNED | TERMINATED (mã tra trong StatusOption entity=PARTNER)
  address       String?
  phone         String?
  email         String?
  contactPerson String?   @map("contact_person")
  createdBy     Int?      @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy     Int?      @map("updated_by")
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy     Int?      @map("deleted_by")

  @@map("partners")
}

// Liên kết Đối tác ↔ Ngân hàng (§C4c, many-to-many). 1 đối tác liên kết nhiều ngân hàng.
// Soft-delete: hủy liên kết = set deletedAt (re-link = clear deletedAt) — không xóa vật lý (R_AUDIT_TRAIL).
model PartnerBank {
  id        Int       @id @default(autoincrement())
  partnerId Int       @map("partner_id")
  bankId    Int       @map("bank_id")
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@unique([partnerId, bankId])
  @@index([partnerId])
  @@index([bankId])
  @@map("partner_banks")
}

// Danh mục trạng thái tùy biến dùng chung (R14). Mỗi thực thể (entity) có bộ trạng thái riêng.
// - isBuiltin=true: trạng thái mặc định hệ thống seed — KHÔNG xóa, KHÔNG đổi `code` (chỉ đổi label/tone/sortOrder/active).
// - Nhóm được phép "thêm mới" điều khiển bằng map cứng ENTITY_ALLOW_ADD trong status-catalog-service (master-data mới cho thêm).
// Cột `status` của các bảng (Bank/Customer/Partner…) lưu `code` tra ở đây theo entity.
model StatusOption {
  id        Int       @id @default(autoincrement())
  entity    String    // BANK | CUSTOMER | PARTNER | POS_DEVICE | HKD_MST | ...
  code      String    // ACTIVE, INACTIVE, LOCKED, SIGNED, ... hoặc custom (CUSTOM_<n>)
  label     String    // nhãn hiển thị: "Đang hoạt động"
  tone      String    @default("slate") // emerald|amber|slate|rose|sky|indigo|violet|brand
  isBuiltin Boolean   @default(false) @map("is_builtin")
  sortOrder Int       @default(0) @map("sort_order")
  active    Boolean   @default(true) // ẩn/hiện trong dropdown chọn (builtin đã gán vẫn hiển thị badge)
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@unique([entity, code])
  @@index([entity])
  @@map("status_options")
}

// ─────────────────────────────────────────────────────────────────────────────
// G-CFG.2 — Chuỗi cung ứng máy POS (§C6 NCC · §C7 Chủng loại · §C8 Nhập kho)
// Mọi cột @unique trên bảng có deletedAt → service xử lý va chạm với bản đã xóa
// mềm (DUPLICATE_TRASH) + lưới P2002 (bài học B05/G-CFG-B01).
// ─────────────────────────────────────────────────────────────────────────────

// Nhà cung cấp máy POS (§C6).
model Supplier {
  id            Int       @id @default(autoincrement())
  name          String
  code          String    @unique
  address       String?
  phone         String?
  contactPerson String?   @map("contact_person")
  createdBy     Int?      @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy     Int?      @map("updated_by")
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy     Int?      @map("deleted_by")

  @@map("suppliers")
}

// Chủng loại máy POS (§C7) — Mã máy + Tên máy.
model PosModel {
  id        Int       @id @default(autoincrement())
  code      String    @unique // mã máy POS
  name      String // tên máy POS
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("pos_models")
}

// Trạng thái nhập máy (§C8a) — ví dụ: Máy mới, máy cũ, Máy đổi, Máy thuê.
model PosIntakeStatus {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("pos_intake_statuses")
}

// Nhập kho máy POS (§C8b) — 1 bản ghi = 1 máy nhập kho công ty. Link scalar tới
// chủng loại / trạng thái / NCC (join ở service, resilient soft-delete).
model PosIntake {
  id             Int       @id @default(autoincrement())
  posModelId     Int       @map("pos_model_id")
  serial         String    @unique // Seri number — chữ+số, không giới hạn
  intakeStatusId Int       @map("intake_status_id")
  supplierId     Int       @map("supplier_id")
  importPrice    Int       @map("import_price") // giá nhập (VND, số nguyên đồng)
  importedAt     DateTime  @map("imported_at") @db.Timestamptz(3) // ngày nhập
  note           String?
  createdBy      Int?      @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy      Int?      @map("updated_by")
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy      Int?      @map("deleted_by")

  @@index([posModelId])
  @@index([supplierId])
  @@index([intakeStatusId])
  @@map("pos_intakes")
}

// ─────────────────────────────────────────────────────────────────────────────
// G-CFG.3 — Cấu hình phí (§C5): Loại phí (C5a) + Biểu phí % theo Đối tác×Loại thẻ (C5b)
// ─────────────────────────────────────────────────────────────────────────────

// Loại phí bán (§C5a) — danh mục: Ủy quyền, Tiền chờ, Tiền Nhanh…
model FeeType {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("fee_types")
}

// Biểu phí % (§C5b) — 1 dòng = 1 tổ hợp Đối tác × Loại thẻ (loại thẻ đã gắn Ngân hàng ở C3).
// Mỗi loại thẻ (Visa/Master/Napas…) của 1 đối tác có biểu phí riêng. Set lại = cập nhật (upsert).
// Phí lưu Int = phần trăm × 1000 (tối đa 3 số thập phân, chính xác tuyệt đối — không dùng float).
// Chênh lệch NCC/KH là cột TÍNH (không lưu): CL_NCC = phiMua−phiCaiMay, CL_KH = phiBan−phiCaiMay.
// P1.1 (GIÁ THEO KỲ): mỗi dòng = 1 KỲ giá của tổ hợp (Đối tác × Loại thẻ), phân biệt bởi
// `effectiveFrom`. Nhiều kỳ cùng tồn tại (lịch sử giá). Phí của 1 GD = kỳ đang hiệu lực tại
// `txnDate` (pickEffectiveRate). KHÔNG @@unique DB (bảng có deletedAt — bài học B05); "1 kỳ/1 mốc"
// enforce ở service. Dòng cũ (mô hình 1-dòng/tổ hợp) backfill effective_from = mốc sàn 1970-01-01.
model FeeRate {
  id           Int       @id @default(autoincrement())
  partnerId    Int       @map("partner_id")
  cardTypeId   Int       @map("card_type_id")
  phiMua       Int       @map("phi_mua") // ×1000
  phiCaiMay    Int       @map("phi_cai_may") // ×1000
  phiBan       Int       @map("phi_ban") // ×1000
  effectiveFrom DateTime @map("effective_from") // ngày bắt đầu hiệu lực của kỳ giá (P1.1)
  createdBy  Int?      @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy  Int?      @map("updated_by")
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy  Int?      @map("deleted_by")

  @@index([partnerId])
  @@index([cardTypeId])
  @@map("fee_rates")
}

// R30 (Mr.Long 11/7) — Phí BÁN THỰC TẾ theo từng TID × Loại thẻ (tùy biến theo khách khi GIAO máy).
// Biểu phí FeeRate (Đối tác × Loại thẻ) chỉ là phí NIÊM YẾT chung; phí bán thật thỏa thuận riêng cho
// mỗi TID/khách/thẻ, nhập lúc giao máy. `phiBan` Int = %×1000 (như FeeRate). resolveFeeForTxn ưu tiên
// override này thay cho FeeRate.phiBan khi tính CL_KH (phí cài máy vẫn lấy từ kỳ FeeRate hiệu lực).
// KHÔNG @@unique DB đầy đủ (có deletedAt — bài học B05). "1 phí / 1 (tid, thẻ) còn sống" enforce ở service
// (setTidSellFees khóa FOR UPDATE hàng tid) + PARTIAL UNIQUE INDEX `tid_sell_fees_active_uq` (WHERE deleted_at
// IS NULL) làm backstop cấp DB — xem migration 20260712100000_r30r34_concurrency_guards.
model TidSellFee {
  id         Int       @id @default(autoincrement())
  tidId      Int       @map("tid_id")
  cardTypeId Int       @map("card_type_id")
  phiBan     Int       @map("phi_ban") // phí BÁN thực tế, ×1000
  createdBy  Int?      @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy  Int?      @map("updated_by")
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy  Int?      @map("deleted_by")

  @@index([tidId])
  @@index([cardTypeId])
  @@map("tid_sell_fees")
}

// ─────────────────────────────────────────────────────────────────────────────
// G-CFG.4 — Tài khoản nhận tiền – ủy quyền (§8): nguồn TK (8a) + TK (8b)
// Ảnh CCCD lưu ngoài DB (docs/FILE_UPLOAD_CONVENTION.md): DB giữ path + tên gốc + checksum.
// ─────────────────────────────────────────────────────────────────────────────

// Nguồn tài khoản ủy quyền (§8a) — ví dụ: Khách hàng, Nội bộ…
model ReceiveAccountSource {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("receive_account_sources")
}

// Tài khoản nhận tiền – ủy quyền (§8b).
model ReceiveAccount {
  id             Int       @id @default(autoincrement())
  sourceId       Int       @map("source_id") // nguồn TK (8a)
  accountName    String    @map("account_name") // Tên tài khoản (chủ TK)
  accountNumber  String    @map("account_number") // STK
  bankId         Int       @map("bank_id") // Ngân hàng
  branch         String? // Chi nhánh
  cccdNumber     String?   @map("cccd_number") // Số CCCD nhận ủy quyền
  cccdIssueDate  DateTime? @map("cccd_issue_date") // Ngày cấp
  cccdIssuePlace String?   @map("cccd_issue_place") // Nơi cấp
  cccdExpiry     DateTime? @map("cccd_expiry") // Ngày hết hạn
  phone          String?
  email          String? // email đối soát
  customerId     Int?      @map("customer_id") // gắn KH (null = nội bộ)
  // Ảnh CCCD (path tương đối trong uploads/ + tên gốc). Mặt sau không bắt buộc.
  cccdFrontPath  String?   @map("cccd_front_path")
  cccdFrontName  String?   @map("cccd_front_name")
  cccdBackPath   String?   @map("cccd_back_path")
  cccdBackName   String?   @map("cccd_back_name")
  note           String?
  createdBy      Int?      @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy      Int?      @map("updated_by")
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy      Int?      @map("deleted_by")

  @@index([sourceId])
  @@index([bankId])
  @@index([customerId])
  @@map("receive_accounts")
}

// ─────────────────────────────────────────────────────────────────────────────
// G-CFG.5 — Quản lý Hồ sơ HKD (§10): nguồn hồ sơ (10a/b) + hồ sơ HKD (10c/d)
// Ảnh ĐKKD + CCCD lưu ngoài DB (docs/FILE_UPLOAD_CONVENTION.md, kind='dossier').
// ─────────────────────────────────────────────────────────────────────────────

// Nguồn hồ sơ (§10a) — mã + chính sách chiết khấu %.
model DossierSource {
  id           Int       @id @default(autoincrement())
  code         String    @unique // Mã nguồn hồ sơ
  discountRate Int       @default(0) @map("discount_rate") // chiết khấu % ×1000 (≤3 thập phân, Int chính xác)
  createdBy    Int?      @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy    Int?      @map("updated_by")
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy    Int?      @map("deleted_by")

  @@map("dossier_sources")
}

// Hồ sơ Hộ Kinh Doanh (§10c). Ảnh ĐKKD/CCCD 2 mặt lưu ngoài DB (path + tên gốc).
model Dossier {
  id               Int       @id @default(autoincrement())
  sourceId         Int       @map("source_id") // nguồn hồ sơ (10a)
  hkdName          String    @map("hkd_name") // Tên Hộ Kinh Doanh
  hkdAddress       String?   @map("hkd_address") // Địa chỉ đăng ký HKD
  taxCode          String?   @map("tax_code") // MST / Mã số ĐK HKD
  mstStatus        String    @default("ACTIVE") @map("mst_status") // Trạng thái MST: ACTIVE=Hoạt động / CLOSED=Đóng
  dkkdIssueDate    DateTime? @map("dkkd_issue_date") // Ngày cấp ĐKKD
  dkkdIssuePlace   String?   @map("dkkd_issue_place") // Nơi cấp ĐKKD
  ownerName        String    @map("owner_name") // Tên chủ hộ kinh doanh
  gender           String? // Giới tính
  ethnicity        String? // Dân tộc
  cccdNumber       String?   @map("cccd_number") // Số CCCD
  cccdIssueDate    DateTime? @map("cccd_issue_date") // Ngày cấp
  cccdIssuePlace   String?   @map("cccd_issue_place") // Nơi cấp
  cccdExpiry       DateTime? @map("cccd_expiry") // Ngày hết hạn
  permanentAddress String?   @map("permanent_address") // Địa chỉ thường trú
  currentAddress   String?   @map("current_address") // Nơi ở hiện tại
  email            String? // Địa chỉ email liên hệ
  // Ảnh ĐKKD (đặt tên theo Tên HKD) + CCCD (đặt tên theo Tên chủ hộ). Mặt sau không bắt buộc.
  dkkdFrontPath    String?   @map("dkkd_front_path")
  dkkdFrontName    String?   @map("dkkd_front_name")
  dkkdBackPath     String?   @map("dkkd_back_path")
  dkkdBackName     String?   @map("dkkd_back_name")
  cccdFrontPath    String?   @map("cccd_front_path")
  cccdFrontName    String?   @map("cccd_front_name")
  cccdBackPath     String?   @map("cccd_back_path")
  cccdBackName     String?   @map("cccd_back_name")
  note             String?
  createdBy        Int?      @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy        Int?      @map("updated_by")
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy        Int?      @map("deleted_by")

  @@index([sourceId])
  @@map("dossiers")
}

// ─────────────────────────────────────────────────────────────────────────────
// G-CFG.7 — Ngành nghề (master, §11 Pha I1). Vận tải, tạp hóa, cà phê… theo ĐKKD.
// PHA I1 = CHỈ master data + trang cấu hình RIÊNG. KHÔNG gắn industryId vào FeeRate/Tid
// ở pha này (đó là I2 — chờ Mr.Long duyệt). Khuôn F10: mã @unique (CodeCounter prefix 'NGH'),
// soft-delete (deletedAt) + audit (createdBy/updatedBy) + DUPLICATE_TRASH + P2002 guard ở service.
// ─────────────────────────────────────────────────────────────────────────────
model Industry {
  id        Int       @id @default(autoincrement())
  code      String    @unique // NGH01, NGH02... (CodeCounter prefix 'NGH')
  name      String
  active    Boolean   @default(true) // đang dùng / ngừng dùng (giữ lịch sử, không xóa cứng)
  note      String?
  createdBy Int?      @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy Int?      @map("updated_by")
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy Int?      @map("deleted_by")

  @@map("industries")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE H1 — Thu–Chi (Cashflow). CashCategory = danh mục khoản THU/CHI (§A/§B spec H).
// affectsPnl = cột chống double-count lợi nhuận accrual (§5). BẤT BIẾN (I#12): sourceKind nội bộ
// (DEBT_*/DEPOSIT/DEPOSIT_REFUND/ADVANCE/DEVICE_DEPOSIT/FUND_TRANSFER) CẤM affectsPnl=true —
// enforce ở cash-category-service (create/update) + selftest. isSystem = seed hệ thống, KHÔNG xóa.
// Tiền = VND nguyên (KHÔNG ×1000). Mọi DateTime @db.Timestamptz(3) + @map snake_case (M6).
// ─────────────────────────────────────────────────────────────────────────────
model CashCategory {
  id         Int       @id @default(autoincrement())
  kind       String // THU | CHI
  name       String
  unit       String? // đơn vị tính (đồng, máy, tháng…)
  periodType String?   @map("period_type") // NONE | MONTH | DATE_RANGE — kỳ áp dụng
  sourceKind String    @default("MANUAL") @map("source_kind") // MANUAL|DEBT_CUSTOMER|DEBT_PARTNER|SALE_POS|SALE_TID|ADVANCE|DEPOSIT|DEPOSIT_REFUND|DEVICE_DEPOSIT|FUND_TRANSFER|SALARY
  affectsPnl Boolean   @default(true) @map("affects_pnl") // có tính vào lợi nhuận accrual (§5) không
  isSystem   Boolean   @default(false) @map("is_system") // danh mục hệ thống (seed) — không cho xóa
  active     Boolean   @default(true)
  createdBy  Int?      @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy  Int?      @map("updated_by")
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy  Int?      @map("deleted_by")

  @@index([kind])
  @@index([sourceKind])
  @@map("cash_categories")
}

// Lịch sử BẢO TRÌ / quét sức khỏe hệ thống (Nhóm E, LEAD 9/7). Mỗi lần quét lưu 1 dòng +
// báo cáo JSON (danh sách phát hiện lỗi/bug + đề xuất fix). Giữ vết để đối chiếu về sau.
model MaintenanceRun {
  id           Int       @id @default(autoincrement())
  kind         String    @default("MANUAL") // MANUAL | SCHEDULED
  status       String    @default("OK") // OK | WARN | ERROR
  checksTotal  Int       @default(0) @map("checks_total")
  issuesFound  Int       @default(0) @map("issues_found")
  errorCount   Int       @default(0) @map("error_count")
  warnCount    Int       @default(0) @map("warn_count")
  reportJson   String?   @map("report_json") // mảng findings {code,severity,title,count,detail,suggestion}
  backupFile   String?   @map("backup_file")
  auditDeleted Int       @default(0) @map("audit_deleted")
  trashDeleted Int       @default(0) @map("trash_deleted")
  vacuumed     Boolean   @default(false)
  autoFixed    Int       @default(0) @map("auto_fixed")
  durationMs   Int       @default(0) @map("duration_ms")
  triggeredBy  Int?      @map("triggered_by")
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz(3)

  @@index([startedAt])
  @@map("maintenance_runs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE H2-core — Thu–Chi (Cashflow): Quỹ (Fund §2.2/J) + Phiếu thu/chi (CashEntry §2.3/D+E).
// Tiền = VND nguyên (KHÔNG ×1000). Mọi DateTime @db.Timestamptz(3) + @map snake_case (M6).
// Số dư quỹ KHÔNG lưu cứng — tính running = openingBalance + Σ THU_POSTED − Σ CHI_POSTED theo fundId
// (I#1, tránh drift R6). Mã QU/PT/PC sinh atomic trong $transaction (§D/R7). Phiếu CANCELLED KHÔNG
// tính vào số dư. amount > 0 (I#4). kind=CHI bắt buộc payerUserId (I#3). Ngày local (I#10, B16).
// ─────────────────────────────────────────────────────────────────────────────
model Fund {
  id             Int       @id @default(autoincrement())
  code           String    @unique // QU01… (H6: prefix 2 ký tự — Q 1 ký tự vi phạm CODE_PREFIX_REGEX)
  name           String // "Quỹ tiền mặt VP", "TK VCB 199…"
  type           String // CASH | BANK | EWALLET
  keeperUserId   Int?      @map("keeper_user_id") // ai giữ quỹ (mục J)
  openingBalance Int       @default(0) @map("opening_balance") // VND — số dư đầu kỳ (KHÔNG lưu số dư hiện tại)
  active         Boolean   @default(true)
  note           String?
  createdBy      Int?      @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy      Int?      @map("updated_by")
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy      Int?      @map("deleted_by")

  @@map("funds")
}

// Phiếu thu/chi — chứng từ nguyên thủy (D + E). status DRAFT|POSTED|CANCELLED (mặc định POSTED).
model CashEntry {
  id             Int       @id @default(autoincrement())
  code           String?   @unique // PT##### (THU) / PC##### (CHI)
  kind           String // THU | CHI
  categoryId     Int       @map("category_id")
  // fundId NULLABLE (H2b): phần lớn phiếu gắn quỹ (thu/chi tiền thật). Riêng phiếu CHI "Chi phí nợ xấu"
  // (ghi giảm nợ xấu, sourceType=BAD_DEBT) là bút toán KHÔNG-tiền-mặt (tiền chưa từng vào quỹ) → fundId=null,
  // KHÔNG trừ số dư quỹ nào (số dư = Σ CashEntry theo fundId), nhưng VẪN vào chi phí lợi nhuận theo categoryId.
  fundId         Int?      @map("fund_id") // quỹ tiền vào/ra (mục J liên thông) — null cho bút toán phi tiền mặt
  amount         Int // VND nguyên, > 0
  method         String // CK | CASH
  entryDate      DateTime  @map("entry_date") @db.Timestamptz(3) // ngày thu/chi (local) — M6
  customerId     Int?      @map("customer_id") // KH (mục D)
  partnerId      Int?      @map("partner_id") // đối tác (mục D)
  payerUserId    Int?      @map("payer_user_id") // NGƯỜI CHI — bắt buộc khi kind=CHI (mục E, I#3)
  receiverUserId Int?      @map("receiver_user_id") // người nhận (thu hộ / hoàn cọc)
  docPath        String?   @map("doc_path")
  docName        String?   @map("doc_name")
  sourceType     String?   @map("source_type") // ADVANCE | DEVICE_DEPOSIT | DEPOSIT_REFUND | SALARY | FUND_TRANSFER | null(thủ công)
  sourceId       Int?      @map("source_id")
  note           String?
  status         String    @default("POSTED") // DRAFT | POSTED | CANCELLED
  cancelReason   String?   @map("cancel_reason")
  cancelledAt    DateTime? @map("cancelled_at") @db.Timestamptz(3)
  createdBy      Int?      @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy      Int?      @map("updated_by")
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedBy      Int?      @map("deleted_by")

  @@index([fundId])
  @@index([categoryId])
  @@index([entryDate])
  @@index([status])
  @@index([customerId])
  @@index([partnerId])
  @@map("cash_entries")
}

// PHASE H2-debt — Nối phiếu thu công nợ (CashEntry kind=THU, category DEBT_*) ↔ Transaction được tất
// toán (§2.4). CHỐNG ĐẾM TRÙNG (net-of-settlement, H4): công nợ còn lại từng side =
//   revenue(side) − Σ CashDebtSettlement.amount(side, GD). Transaction.settled chỉ là HỆ QUẢ, set=true
// KHI VÀ CHỈ KHI cả 2 side net=0 (trong cùng $transaction tạo phiếu). Hủy phiếu thu công nợ → xóa các
// dòng settlement + tính lại settled (M3). KHÔNG dùng cờ settled làm nguồn tính nợ.
model CashDebtSettlement {
  id            Int      @id @default(autoincrement())
  cashEntryId   Int      @map("cash_entry_id") // phiếu thu (kind=THU, category DEBT_*)
  transactionId Int      @map("transaction_id") // GD được tất toán
  side          String // PARTNER | SELL (CL_NCC — chênh đối tác / CL_KH — chênh bán)
  amount        Int // VND áp vào GD này (> 0)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([cashEntryId])
  @@index([transactionId])
  @@map("cash_debt_settlements")
}

// PHASE H2b — Lịch sử đổi phân loại chất lượng công nợ (§2.8, LEAD 10/7). Mỗi lần classifyDebt ghi 1 dòng
// (from→to + lý do + người đổi). toQuality ∈ GOOD|HARD|BAD; fromQuality null nếu trước đó CHƯA phân loại.
model DebtQualityLog {
  id            Int      @id @default(autoincrement())
  transactionId Int      @map("transaction_id")
  fromQuality   String?  @map("from_quality")
  toQuality     String   @map("to_quality")
  reason        String?
  actorUserId   Int      @map("actor_user_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([transactionId])
  @@map("debt_quality_logs")
}
